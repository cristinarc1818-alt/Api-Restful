{
  "openapi": "3.0.1",
  "info": {
    "title": "API de Gestión de Libros",
    "description": "API RESTful para administrar un catálogo de libros con operaciones CRUD completas",
    "contact": {
      "name": "Tu Nombre",
      "email": "tu@email.com"
    },
    "version": "v1.0"
  },
  "paths": {
    "/api/Libros": {
      "get": {
        "tags": [
          "Libros"
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/LibroDto"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Libros"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateLibroDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateLibroDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateLibroDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LibroDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/Libros/{id}": {
      "get": {
        "tags": [
          "Libros"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
